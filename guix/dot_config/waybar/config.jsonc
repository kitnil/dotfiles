// -*- mode: jsonc -*-
{
    // "id": "bar-0",
    "ipc": true,
    // "layer": "top", // Waybar at top layer
    "position": "bottom", // Waybar position (top|bottom|left|right)
    "height": 30, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    "spacing": 4, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": [
        "custom/media"
    ],
    // "wlr/taskbar"
    "modules-right": [
        // "mpd",
        "custom/ddc-switch-output",
        "idle_inhibitor",
        "custom/lm-studio-models",
        "pulseaudio",
        "network#eth0",
        "network#tapvpn",
        "network#tapvpn1",
        "power-profiles-daemon",
        "cpu",
        "temperature",
        "memory",
        "disk#/",
        "backlight",
        "keyboard-state",
        "clock#utc",
        "clock#msk",
        "tray"
    ],
    // Modules configuration
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "’ĆŻ",
            "unlocked": "’é£"
        }
    },
    "custom/lm-studio-models": {
        "exec": "/home/oleg/src/cgit.wugi.info/wigust/dotfiles/guix/dot_local/bin/lm-studio-loaded-models.sh",
        "return-type": "json",
        "interval": 2,
        "tooltip": true,
        "format": "{text}  ’Ģä",
        "on-click": "alacritty --command /home/oleg/src/cgit.wugi.info/wigust/dotfiles/guix/dot_local/bin/llm-watch-primary"
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 16,
        "icon-theme": "Adwaita",
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },
    "custom/ddc-switch-output": {
        "format": "DDC",
        "icon-size": 16,
        "icon-theme": "Adwaita",
        "tooltip-format": "Switch output on DP-1",
        // hdmi-2
        "on-click": "sudo ddcutil --bus=7 setvcp xF4 x0091 --i2c-source-addr=x50 --noverify",
        // dp-1
        "on-click-right": "sudo ddcutil --bus=7 setvcp xF4 x00d0 --i2c-source-addr=x50 --noverify",
    },
    "mpd": {
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) ŌĖ©{songPosition}|{queueLength}ŌĖ® {volume}% ’Ćü",
        "format-disconnected": "Disconnected ’Ćü",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped ’Ćü",
        "unknown-tag": "N/A",
        "interval": 5,
        "consume-icons": {
            "on": "’āä "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\">’ü┤</span> ",
            "on": "’ü┤ "
        },
        "repeat-icons": {
            "on": "’Ć× "
        },
        "single-icons": {
            "on": "’Ć×1 "
        },
        "state-icons": {
            "paused": "’üī",
            "playing": "’üŗ"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "’ü«",
            "deactivated": "’ü░"
        }
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock#utc": {
        "timezone": "UTC",
        "format": "{:%H:%M} UTC",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "clock#msk": {
        "timezone": "Europe/Moscow",
        "format": "{:%H:%M MSK        %Y-%m-%d}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}",
        "calendar": {
	    "mode"          : "year",
	    "mode-mon-col"  : 3,
	    "weeks-pos"     : "right",
	    "on-scroll"     : 1,
	    "on-click-right": "mode",
	    "format": {
		"months":     "<span color='#ffffff'><b>{}</b></span>",
		"days":       "<span color='#ffffff'><b>{}</b></span>",
		"weeks":      "<span color='#d3d3d3'><b>W{}</b></span>",
		"weekdays":   "<span color='#d3d3d3'><b>{}</b></span>",
		"today":      "<span color='#90ee90'><b><u>{}</u></b></span>"
	    }
	},
    },
    "cpu": {
        "format": "{usage}%  ’ŗø",
        "tooltip": false,
        "on-click": "alacritty --command ssh -t 192.168.0.192 htop"
    },
    "memory": {
        "format": "{percentage}%  ’āē    {swapPercentage}% Swap"
    },
    "temperature": {
        // "thermal-zone": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
        "critical-threshold": 80,
        "format-critical": "{temperatureC}┬░C {icon}",
        "format": "{temperatureC} ┬░C",
        "format-icons": ["’Ø½", "’ŗē", "’Ø®"]
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["ŅÄŹ", "ŅÅō", "ŅÅæ", "ŅÅÅ", "ŅÅÄ", "ŅÅŹ", "ŅÅŖ", "ŅÅł", "ŅÄø"]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-full": "{capacity}% {icon}",
        "format-charging": "{capacity}% ’Ś¦",
        "format-plugged": "{capacity}% ’ć”",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "tooltip": true,
      "format-icons": {
        "default": "’ā¦",
        "performance": "’ā¦",
        "balanced": "’ēÄ",
        "power-saver": "’ü¼"
      }
    },
    "network#eth0": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%)  ’ć½",
        "format-ethernet": "{bandwidthDownBits} ’äā    {bandwidthUpBits} ’äé",
        "tooltip-format": "{ipaddr}/{cidr} {ifname} via {gwaddr}",
        "format-linked": "{ifname} (No IP)  ’×¢",
        "format-disconnected": "DOWN  ŌÜĀ",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "network#tapvpn": {
        "interface": "tapvpn",
        "format-wifi": "{essid} ({signalStrength}%)  ’ć½",
        "format-ethernet": "{bandwidthDownBits} ’äā    {bandwidthUpBits} ’äé",
        "tooltip-format": "{ipaddr}/{cidr} {ifname} via {gwaddr}",
        "format-linked": "{ifname} (No IP)  ’×¢",
        "format-disconnected": "DOWN  ’åŁ",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "/home/oleg/src/cgit.wugi.info/wigust/dotfiles/guix/dot_local/bin/herd-toggle-service.sh"
    },
    "network#tapvpn1": {
        "interface": "tapvpn1",
        "format-wifi": "{essid} ({signalStrength}%)  ’ć½",
        "format-ethernet": "{bandwidthDownBits} ’äā    {bandwidthUpBits} ’äé",
        "tooltip-format": "{ipaddr}/{cidr} {ifname} via {gwaddr}",
        "format-linked": "{ifname} (No IP)  ’×¢",
        "format-disconnected": "DOWN  ’ĆĢ",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "/home/oleg/src/cgit.wugi.info/wigust/dotfiles/guix/dot_local/bin/herd-toggle-service.sh"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}%  {icon} {format_source}",
        "format-bluetooth": "{volume}%  {icon}’Ŗö {format_source}",
        "format-bluetooth-muted": "’Ü® {icon}’Ŗö {format_source}",
        "format-muted": "’Ü® {format_source}",
        "format-source": "    {volume}%  ’ä░",
        "format-source-muted": "’ä▒",
        "format-icons": {
            "headphone": "’Ćź",
            "hands-free": "’¢É",
            "headset": "’¢É",
            "phone": "’éĢ",
            "portable": "’éĢ",
            "car": "’å╣",
            "default": ["’Ć”", "’Ć¦", "’Ć©"]
        },
        "on-click": "pavucontrol"
    },
    "disk#/": {
	"interval": 30,
        "path": "/",
	"format": "{percentage_used}%  {path}",
    },
    "custom/media": {
        "format": "{icon} {text}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "’å╝",
            "default": "­¤Ä£"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
        // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    },
    "custom/power": {
        "format" : "ŌÅ╗ ",
		"tooltip": false,
		"menu": "on-click",
		"menu-file": "$HOME/.config/waybar/power_menu.xml", // Menu file in resources folder
		"menu-actions": {
			"shutdown": "shutdown",
			"reboot": "reboot",
			"suspend": "systemctl suspend",
			"hibernate": "systemctl hibernate"
		}
    }
}
