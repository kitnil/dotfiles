// -*- mode: jsonc -*-
{
    // "id": "bar-0",
    "ipc": true,
    // "layer": "top", // Waybar at top layer
    "position": "bottom", // Waybar position (top|bottom|left|right)
    "height": 30, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    "spacing": 4, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": [
        "niri/workspaces",
        "niri/window",
        "custom/media"
    ],
    "modules-right": [
        // "mpd",
        "custom/ddc-switch-output",
        "idle_inhibitor",
        "custom/lm-studio-models",
        "pulseaudio",
        "network#eth0",
        "power-profiles-daemon",
        "cpu",
        "temperature",
        "memory",
        "disk#/",
        "backlight",
        "keyboard-state",
        "clock#utc",
        "clock#msk",
        "tray",
        "custom/notification"
    ],
    // Modules configuration
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "пА£",
            "unlocked": "пВЬ"
        }
    },
    "custom/notification": {
        "tooltip": true,
        "format": "<span size='16pt'>{icon}</span>",
        "format-icons": {
          "notification": "у±ЕЂ",
          "none": "у∞ВЬ",
          "dnd-notification": "у∞В†",
          "dnd-none": "у∞™У",
          "inhibited-notification": "у∞ВЫ",
          "inhibited-none": "у∞™С",
          "dnd-inhibited-notification": "у∞ВЫ",
          "dnd-inhibited-none": "у∞™С"
        },
        "return-type": "json",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "custom/lm-studio-models": {
        "exec": "/home/oleg/src/cgit.wugi.info/wigust/dotfiles/guix/dot_local/bin/lm-studio-loaded-models.sh",
        "return-type": "json",
        "interval": 2,
        "tooltip": true,
        "format": "{text}  пХД",
        "on-click": "alacritty --command /home/oleg/src/cgit.wugi.info/wigust/dotfiles/guix/dot_local/bin/llm-watch-primary"
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 16,
        "icon-theme": "Adwaita",
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close"
    },
    "custom/ddc-switch-output": {
        "format": "DDC",
        "icon-size": 16,
        "icon-theme": "Adwaita",
        "tooltip-format": "Switch output on DP-1",
        // hdmi-2
        "on-click": "/home/oleg/src/cgit.wugi.info/wigust/dotfiles/guix/dot_local/bin/ddc --output=HDMI-2",
        // dp-1
        "on-click-right": "/home/oleg/src/cgit.wugi.info/wigust/dotfiles/guix/dot_local/bin/ddc --output=DP-1",
    },
    "mpd": {
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) вЄ®{songPosition}|{queueLength}вЄ© {volume}% пАБ",
        "format-disconnected": "Disconnected пАБ",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped пАБ",
        "unknown-tag": "N/A",
        "interval": 5,
        "consume-icons": {
            "on": "пГД "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\">пБі</span> ",
            "on": "пБі "
        },
        "repeat-icons": {
            "on": "пАЮ "
        },
        "single-icons": {
            "on": "пАЮ1 "
        },
        "state-icons": {
            "paused": "пБМ",
            "playing": "пБЛ"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "пБЃ",
            "deactivated": "пБ∞"
        }
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock#utc": {
        "timezone": "UTC",
        "format": "{:%H:%M} UTC",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}"
    },
    "clock#msk": {
        "timezone": "Europe/Moscow",
        "format": "{:%H:%M MSK        %Y-%m-%d}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%Y-%m-%d}",
        "calendar": {
	    "mode"          : "year",
	    "mode-mon-col"  : 3,
	    "weeks-pos"     : "right",
	    "on-scroll"     : 1,
	    "on-click-right": "mode",
	    "format": {
		"months":     "<span color='#ffffff'><b>{}</b></span>",
		"days":       "<span color='#ffffff'><b>{}</b></span>",
		"weeks":      "<span color='#d3d3d3'><b>W{}</b></span>",
		"weekdays":   "<span color='#d3d3d3'><b>{}</b></span>",
		"today":      "<span color='#90ee90'><b><u>{}</u></b></span>"
	    }
	},
    },
    "cpu": {
        "format": "{usage}%  пЛЫ",
        "tooltip": false,
        "on-click": "alacritty --command ssh -t 192.168.0.192 htop"
    },
    "memory": {
        "format": "{percentage}%  пГЙ    {swapPercentage}% Swap"
    },
    "temperature": {
        // "thermal-zone": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
        "critical-threshold": 80,
        "format-critical": "{temperatureC}¬∞C {icon}",
        "format": "{temperatureC} ¬∞C",
        "format-icons": ["пЭЂ", "пЛЙ", "пЭ©"]
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["оОН", "оПУ", "оПС", "оПП", "оПО", "оПН", "оПК", "оПИ", "оОЫ"]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-full": "{capacity}% {icon}",
        "format-charging": "{capacity}% пЧІ",
        "format-plugged": "{capacity}% пЗ¶",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "tooltip": true,
      "format-icons": {
        "default": "пГІ",
        "performance": "пГІ",
        "balanced": "пЙО",
        "power-saver": "пБђ"
      }
    },
    "network#eth0": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%)  пЗЂ",
        "format-ethernet": "{bandwidthDownBits} пДГ    {bandwidthUpBits} пДВ",
        "tooltip-format": "{ipaddr}/{cidr} {ifname} via {gwaddr}",
        "format-linked": "{ifname} (No IP)  пЮЦ",
        "format-disconnected": "DOWN  вЪ†",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}%  {icon} {format_source}",
        "format-bluetooth": "{volume}%  {icon}пКФ {format_source}",
        "format-bluetooth-muted": "пЪ© {icon}пКФ {format_source}",
        "format-muted": "пЪ© {format_source}",
        "format-source": "    {volume}%  пД∞",
        "format-source-muted": "пД±",
        "format-icons": {
            "headphone": "пА•",
            "hands-free": "пЦР",
            "headset": "пЦР",
            "phone": "пВХ",
            "portable": "пВХ",
            "car": "пЖє",
            "default": ["пА¶", "пАІ", "пА®"]
        },
        "on-click": "pavucontrol"
    },
    "disk#/": {
	"interval": 30,
        "path": "/",
	"format": "{percentage_used}%  {path}",
    },
    "custom/media": {
        "format": "{icon} {text}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "пЖЉ",
            "default": "рЯОЬ"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
        // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    },
    "custom/power": {
        "format" : "вПї ",
		"tooltip": false,
		"menu": "on-click",
		"menu-file": "$HOME/.config/waybar/power_menu.xml", // Menu file in resources folder
		"menu-actions": {
			"shutdown": "shutdown",
			"reboot": "reboot",
			"suspend": "systemctl suspend",
			"hibernate": "systemctl hibernate"
		}
    }
}
