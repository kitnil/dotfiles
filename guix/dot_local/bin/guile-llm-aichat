(define-module (llm-aichat)
  #:use-module (json)
  #:use-module (ice-9 rdelim)
  #:use-module (ice-9 match)
  #:use-module (ice-9 popen)
  #:use-module (srfi srfi-71)
  #:use-module (srfi srfi-37)
  #:use-module (rnrs bytevectors)
  #:use-module (web client)
  #:use-module (web request)
  #:use-module (web response)
  #:export (main))

;;; Commentary:
;;;
;;; DESCRIPTION
;;;
;;; Code:

(define %options
  (let ((display-and-exit-proc (lambda (msg)
                                 (lambda (opt name arg loads)
                                   (display msg) (quit)))))
    (list (option '(#\v "version") #f #f
                  (display-and-exit-proc "llm-aichat version 0.0.1\n"))
          (option '(#\h "help") #f #f
                  (display-and-exit-proc
                   "Usage: llm-aichat ...")))))

(define %default-options
  '())

(define (main args)
  (define opts
    (args-fold (cdr (program-arguments))
               %options
               (lambda (opt name arg loads)
                 (error "Unrecognized option `~A'" name))
               (lambda (op loads)
                 (cons op loads))
               %default-options))
  (define input (with-input-from-port (current-input-port) read-string))
  (unless (string-null? input)
    (case (string->symbol (getenv "XDG_CURRENT_DESKTOP"))
      ((niri)
       (let* ((port (open-pipe* OPEN_READ "niri" "msg" "--json" "focused-window"))
              (output (read-string port)))
         (close-port port)
         (define window-title
           (assoc-ref (json-string->scm (string-trim-right output #\newline))
                      "title"))
         (define prompts
           (cond
            ((string= window-title "Alacritty")
             '("Explain in English. In not more than 5 sentences without new lines and without saying what you are doing."))
            ((string-prefix? window-title "COMMIT_EDITMSG")
             '("Generate Git commit message following Changelog style. First commit line should end with a period as a sentence. Each modified file should be described as in example \"* /a/b/c.txt: Add something.\". Without saying what you are doing. Limit is 200 characters."))
            ;; TODO: Twitch prompt.
            ((string= window-title "twitch")
             '("Respond in Russian. In one sentence without new lines and without saying what you are doing. Maybe include a joke."))
            (else
             '("Respond in English. In one sentence without new lines and without saying what you are doing."
               "Respond in Russian. In one sentence without new lines and without saying what you are doing."))))
         (for-each (lambda (prompt)
                     (for-each (lambda (endpoint)
                                 (for-each (lambda (model)
                                             (let* ((response port (http-request endpoint
                                                                                 #:method 'POST
                                                                                 #:streaming? #f
                                                                                 #:body (scm->json-string
                                                                                         `(("stream" . #f)
                                                                                           ("system" . ,prompt)
                                                                                           ("prompt" . ,input)
                                                                                           ("model" . ,model)))))
                                                    (body (assoc-ref (json-string->scm (utf8->string port))
                                                                     "response")))
                                               (newline)
                                               (display body)
                                               (system* "fyi" "--app-name=llm-aichat" "--expire-time=300000" model body)))
                                           (cond
                                            ((string= endpoint "http://192.168.0.156:11434/api/generate")
                                             '("deepseek-r1:8b"))
                                            ((string= endpoint "http://192.168.0.185:11434/api/generate")
                                             '("gemma3:12b"
                                               "qwen3:8b")))))
                               '("http://192.168.0.156:11434/api/generate"
                                 "http://192.168.0.185:11434/api/generate")))
                   prompts))))))

;;; Buffer name ‘llm-aichat’ is in use ends here
