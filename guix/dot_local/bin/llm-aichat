#!/usr/bin/env bash

set -o errexit -o pipefail

PATH="/gnu/store/8s03yp79faafp1vnjp8xggrqsf22xxp9-fyi-1.0.4/bin:${PATH}"
export PATH

NOTIFY="${LLM_AICHAT_NOTIFY:-false}"
WINDOW_MANAGER="${LLM_AICHAT_WINDOW_MANAGER:-niri}"

current_window_name()
{
    if [[ $WINDOW_MANAGER == niri ]]
    then
        niri msg --json focused-window | jq --raw-output .title
    elif [[ $WINDOW_MANAGER == sway ]]
    then
        swaymsg -t get_tree | jq --raw-output '.. | select(.focused?) | .name'
    fi
}

notify()
{
    if [[ $NOTIFY == true ]]
    then
        fyi "$@"
    else
        echo "$@"
    fi
}

main()
{
    local content="$(cat)"
    if [[ -z $content ]]
    then
        exit 0
    fi
    printf "%s\n" "$content"
    if [[ -n $LLM_PROMPT ]]
    then
        local prompts=(
            "$LLM_PROMPT"
        )
    else
        case "$(current_window_name)" in
            Alacritty)
                local prompts=(
                    "Explain in English. In not more than 5 sentences without new lines and without saying what you are doing."
                )
                ;;
            COMMIT_EDITMSG*|magit-diff*)
                local prompts=(
                    'Generate Git commit message following Changelog style. First commit line should end with a period as a sentence. Each modified file should be described as in example "* /a/b/c.txt: Add something.". Without saying what you are doing. Limit is 200 characters.'
                )
                ;;
            *Twitch*)
                local prompts=(
                    "Respond in Russian. In one sentence without new lines and without saying what you are doing. Maybe include a joke."
                )
                ;;
            *)
                local prompts=(
                    "Respond in English. In one sentence without new lines and without saying what you are doing."
                    "Respond in Russian. In one sentence without new lines and without saying what you are doing."
                )
                ;;
        esac
    fi
    for prompt in "${prompts[@]}"
    do
        if [[ -n $content ]]
        then
            local output="$(printf "$content" | aichat --prompt "$prompt")"
            echo "$output"
            russian()
            {
                notify "LLM output (copied to primary clipboard)" "$output"
                if [[ $LLM_COPY == true ]]
                then
                    wl-copy "$output"
                fi
                if [[ $LLM_COPY_PRIMARY == true ]]
                then
                    wl-copy --primary "$output"
                fi
                if [[ $LLM_WTYPE == true ]]
                then
                    wtype "$output"
                fi
            }
            case "$prompt" in
                "Respond in Russian. In one sentence without new lines and without saying what you are doing.")
                    russian
                    ;;
                "Respond in Russian. In one sentence without new lines and without saying what you are doing. Maybe include a joke.")
                    russian
                    ;;
                "Ask extra question in the same language as query without saying what you are doing. Replace вы with ты.")
                    russian
                    ;;
                'Generate Git commit message following Changelog style. First commit line should end with a period as a sentence. Each modified file should be described as in example "* /a/b/c.txt: Add something.". Without saying what you are doing. Limit is 200 characters.')
                    russian
                    ;;
                *)
                    notify "LLM output" "$output"
                    ;;
            esac
        fi
    done
}

main "$@"
