#!/usr/bin/env -S guile --no-auto-compile -e main -s
!#
(use-modules (json)
             (ice-9 popen)
             (ice-9 rdelim)
             (srfi srfi-1))

(define (swaymsg . args)
  (let* ((port   (apply open-pipe* OPEN_READ "swaymsg" args))
         (output (read-string port)))
    (close-port port)
    (string-trim-right output #\newline)))

(define (find-focused node)
  (if (not (assoc-ref node "focused"))
      (or (and (assoc-ref node "nodes")
               (array? (assoc-ref node "nodes"))
               (not (null? (array->list (assoc-ref node "nodes"))))
               (any find-focused (array->list (assoc-ref node "nodes"))))
          (and (assoc-ref node "floating_nodes")
               (array? (assoc-ref node "floating_nodes"))
               (not (null? (array->list (assoc-ref node "floating_nodes"))))
               (any find-focused (array->list (assoc-ref node "floating_nodes")))))
      node))

(define %outputs
  '("DP-1" "HDMI-A-1"))

(define (main . args)
  (define app-id
    (assoc-ref (find-focused (json-string->scm (swaymsg "-t" "get_tree")))
               "app_id"))
  (case (string->symbol app-id)
    ((looking-glass-client)
     #f)
    (else
     (for-each (lambda (output)
                 (system* "swaymsg" "output" output "dpms" "off"))
               %outputs))))
