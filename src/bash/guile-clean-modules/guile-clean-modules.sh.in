#!@SHELL@

set -o nounset -o errexit -o pipefail

mapfile -t files < <(find guix -name '*.scm')

for file in "${files[@]}"
do
    mapfile -t modules < <(src/guile/guix-guile-next-compile-file/guix-guile-next-compile-file --channels=guix/wugi/etc/guix/channels/workstation.scm --file="$file" |& awk '/warning: unused module/' | cut -d: -f 5 | sed 's/ unused module //')

    for module in "${modules[@]}"
    do
        sed -i "/$module/d" "$file"
    done
done
