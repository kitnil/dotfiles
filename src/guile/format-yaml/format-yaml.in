#!@GUILE@ \
--no-auto-compile -e main -s
!#

(use-modules (ice-9 format)
             (ice-9 popen)
             (ice-9 rdelim)
             (srfi srfi-1)
             (wugi utils))

(define %flux-kustomizations
  '(maintenance-guix-system-build-guixsd
    maintenance-guix-system-build-notebook
    maintenance-guix-system-build-pc0
    maintenance-guix-system-build-vm1
    maintenance-guix-system-build-vm2
    maintenance-guix-system-reconfigure-kube1
    maintenance-guix-system-reconfigure-kube2
    maintenance-guix-system-reconfigure-kube3
    maintenance-nix-build-container-systemd-kube1
    runc-nix-builder-nixos-rebuild-switch-flake-kube1))

(define (invoke program . args)
  "Invoke PROGRAM with the given ARGS.  Raise an error if the exit
code is non-zero; otherwise return #t."
  (let ((status (apply system* program args)))
    (unless (zero? status)
      (error (format #f "program ~s exited with non-zero code" program)
             status))
    #t))

(define (git-output . args)
  "Execute 'git ARGS ...' command and return its output without trailing
newspace."
  (let* ((port (apply open-pipe* OPEN_READ "@GIT@" args))
         (output (read-string port)))
    (close-pipe port)
    (string-trim-right output #\newline)))

(define (main . args)
  (define commit-hash
    (or (getenv "GIT_COMMIT")
        (git-output "rev-parse" "HEAD")))
  (for-each (lambda (kustomization)
              (let ((job-file (string-append "flux/apps/cluster1/"
                                             (symbol->string kustomization)
                                             "/job.yaml")))
                (when (file-exists? job-file)
                  (invoke "@YQ@"
                          "-i"
                          (format #f ".spec.template.spec.containers[] |= (select(.name == ~s)).env[] |= (select(.name == ~s).value = ~s)"
                                  "nsenter"
                                  "GIT_COMMIT"
                                  commit-hash)
                          job-file)
                  (invoke "@YAMLFMT@"
                          "-conf" (string-append %distro-directory
                                                 "/dotfiles/dot_yamlfmt")
                          job-file)
                  (system* "@GIT@"
                           "commit"
                           (format #f "--message=~a"
                                   (string-append (string-join (string-split job-file #\/) ": ")
                                                  ": Update to " (list->string (take (string->list commit-hash) 8)) "."))
                           job-file))))
            %flux-kustomizations))
