	Quality >= 1
	Class == "Skill Gems" "Support Gems" 
	MinimapIcon 1 White Triangle
	SetBorderColor 30 190 190 255
	SetTextColor 30 190 190 255
	PlayAlertSound 2 300
	PlayEffect Grey

Show
	BaseType == "Awakened Ancestral Call Support" "Awakened Brutality Support" "Awakened Cast On Critical Strike Support" "Awakened Chain Support" "Awakened Elemental Damage with Attacks Support" "Awakened Empower Support" "Awakened Enhance Support" "Awakened Enlighten Support" "Awakened Fork Support" "Awakened Generosity Support" "Awakened Greater Multiple Projectiles Support" "Awakened Increased Area of Effect Support" "Awakened Melee Physical Damage Support" "Awakened Multistrike Support" "Awakened Spell Cascade Support" "Awakened Spell Echo Support" "Awakened Swift Affliction Support" "Awakened Unbound Ailments Support" "Awakened Unleash Support" "Awakened Void Manipulation Support" 
	Class == "Skill Gems" "Support Gems" 
	MinimapIcon 0 Red Star
	SetBorderColor 255 0 0 255
	SetBackgroundColor 255 255 255 255
	SetTextColor 255 0 0 255
	PlayAlertSound 6 300
	PlayEffect Red

Show
	BaseType "Awakened" 
	Class == "Skill Gems" "Support Gems" 
	MinimapIcon 0 Red Star
	SetBorderColor 255 0 0 255
	SetBackgroundColor 255 255 255 255
	SetTextColor 255 0 0 255
	PlayAlertSound 6 300
	PlayEffect Red

Show
	Class == "Skill Gems" "Support Gems" 
	MinimapIcon 0 Red Star
	SetBorderColor 255 0 0 255
	SetBackgroundColor 255 255 255 255
	SetTextColor 255 0 0 255
	PlayAlertSound 6 300
	PlayEffect Red
	TransfiguredGem True

# Highlight Rogue markers.
Show
	BaseType "Rogue's Marker" 
	SetBorderColor 255 178 135 255
	SetBackgroundColor 20 20 0 255
	SetTextColor 255 178 135 255
	PlayEffect Orange

# Highlight Blueprints and Contracts and Sanctum.
Show
	Class == "Blueprints" "Contracts" "Sanctum Research" 
	MinimapIcon 1 Yellow UpsideDownHouse
	SetBorderColor 255 85 85 255
	SetBackgroundColor 40 0 30 255
	SetTextColor 255 85 85 255
