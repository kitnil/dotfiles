apiVersion: v1
clusters:
- cluster:
    certificate-authority: /var/lib/secrets/ca.pem
    server: https://vm30.intr:6444
  name: virt
contexts:
- context:
    cluster: virt
    user: admin
  name: virt
current-context: virt
kind: Config
preferences: {}
users:
- name: admin
  user:
    client-certificate: /var/lib/secrets/admin.pem
    client-key: /var/lib/secrets/admin-key.pem
