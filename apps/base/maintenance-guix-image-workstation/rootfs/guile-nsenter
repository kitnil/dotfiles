(define %options
  (let ((display-and-exit-proc (lambda (msg)
                                 (lambda (opt name arg loads)
                                   (display msg) (quit)))))
    (list (option '(#\v "version") #f #f
                  (display-and-exit-proc "executable_guile-nsenter version 0.0.1\n"))
          (option '(#\h "help") #f #f
                  (display-and-exit-proc
                   "Usage: executable_guile-nsenter ...")))))

(define %default-options
  '())

(define (runc-code)
  '(begin
     (use-modules (ice-9 format)
                  (ice-9 rdelim))
     (format #t "hostname: ~a~%" (with-input-from-file "/etc/hostname" read-string))
     (format #t "HOME: ~a~%" (getenv "HOME"))))

(define (kubectl-program)
  ;; TODO: Do not hardcode Kubernetes namespace.
  ;; TODO: Do not hardcode uid and gid.
  ;; TODO: Do not hardcode runc container name.
  `(begin
     (setenv "KUBECONFIG" "/home/oleg/.kube/config")
     (system* "kubectl" "--namespace=guix"
              "exec" "--stdin=true" "pod/runc-kube1-guix-builder" "--"
              "runc" "exec" "-u" "1000:998" "guix-builder"
              "/run/current-system/profile/bin/guile"
              "-c" ,(with-output-to-string (lambda () (write (runc-code)))))))

(define (main args)
  (define opts
    (args-fold (cdr (program-arguments))
               %options
               (lambda (opt name arg loads)
                 (error "Unrecognized option `~A'" name))
               (lambda (op loads)
                 (cons op loads))
               %default-options))
  (system* "nsenter"
           (format #f "--target=~a" (number->string 1))
           "--mount"
           "--uts"
           "--ipc"
           "--net"
           "--pid"
           "--no-fork"
           ;; TODO: Do not hardcode uid and gid.
           (format #f "--setuid=~a" (number->string 1000))
           (format #f "--setgid=~a" (number->string 998))
           "/run/current-system/profile/bin/guile"
           "-c" (with-output-to-string (lambda () (write (kubectl-program))))))

