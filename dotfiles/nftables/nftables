table ip nat {
	chain PREROUTING {
		type nat hook prerouting priority dstnat; policy accept;
	}

	chain INPUT {
		type nat hook input priority 100; policy accept;
	}

	chain OUTPUT {
		type nat hook output priority -100; policy accept;
	}

	chain POSTROUTING {
		type nat hook postrouting priority srcnat; policy accept;
	}
}
table ip filter {
	chain INPUT {
		type filter hook input priority filter; policy drop;
		ct state related,established counter packets 0 bytes 0 accept
		ip saddr 192.168.25.1 tcp sport 1080 counter packets 0 bytes 0 accept
		ip saddr 192.168.25.1 udp sport 1195 counter packets 0 bytes 0 accept
		ip saddr 78.108.82.44 udp sport 1195 counter packets 0 bytes 0 accept
		ip saddr 192.168.0.0/24 counter packets 0 bytes 0 accept
		ip saddr 10.0.0.0/8 counter packets 0 bytes 0 accept
		ip saddr 192.168.25.0/24 tcp dport 16400 counter packets 0 bytes 0 drop
		ip saddr 192.168.25.0/24 tcp dport 22 counter packets 0 bytes 0 drop
		ip saddr 192.168.25.0/24 tcp dport 5900 counter packets 0 bytes 0 drop
		ip saddr 192.168.25.0/24 tcp dport 9091 counter packets 0 bytes 0 drop
		ip saddr 192.168.25.0/24 udp dport 16400 counter packets 0 bytes 0 drop
		ip saddr 192.168.25.0/24 udp dport 22 counter packets 0 bytes 0 drop
		ip saddr 192.168.25.0/24 udp dport 5900 counter packets 0 bytes 0 drop
		ip saddr 192.168.25.0/24 udp dport 9091 counter packets 0 bytes 0 drop
		ip saddr 192.168.25.1 udp dport 58458 counter packets 0 bytes 0 accept
		ip saddr 192.168.25.1 tcp dport 58458 counter packets 0 bytes 0 accept
		meta l4proto icmp ip saddr 192.168.25.0/24 counter packets 0 bytes 0 accept
		meta l4proto icmp ip saddr 78.108.82.44/32 counter packets 0 bytes 0 accept
	}

	chain FORWARD {
		type filter hook forward priority filter; policy accept;
		iifname "tapvpn1" counter packets 0 bytes 0 drop
	}

	chain OUTPUT {
		type filter hook output priority filter; policy accept;
	}
}
