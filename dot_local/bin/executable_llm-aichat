#!/usr/bin/env bash

set -o errexit -o pipefail

PATH="/gnu/store/8s03yp79faafp1vnjp8xggrqsf22xxp9-fyi-1.0.4/bin:${PATH}"
export PATH

main()
{
    local content="$(cat)"
    printf "%s\n" "$content"
    current_window_name="$(swaymsg -t get_tree | jq -r '.. | select(.focused?) | .name')"
    if [[ -n $LLM_PROMPT ]]
    then
        local prompts=(
            "$LLM_PROMPT"
        )
    else
        case "$current_window_name" in
            Alacritty)
                local prompts=(
                    "Explain in English. In not more than 5 sentences without new lines and without saying what you are doing."
                )
                ;;
            *)
                local prompts=(
                    "Respond in English. In one sentence without new lines and without saying what you are doing."
                    "Respond in Russian. In one sentence without new lines and without saying what you are doing."
                )
                ;;
        esac
    fi
    for prompt in "${prompts[@]}"
    do
        if [[ -n $content ]]
        then
            local output="$(printf "$content" | /home/oleg/.local/share/chezmoi/dot_local/bin/aichat --prompt "$prompt")"
            echo "$output"
            if [[ $prompt == "Respond in Russian. In one sentence without new lines and without saying what you are doing." ]]
            then
                fyi "LLM output (copied to primary clipboard)" "$output"
                if [[ $LLM_COPY == true ]]
                then
                    wl-copy "$output"
                fi
                if [[ $LLM_COPY_PRIMARY == true ]]
                then
                    wl-copy --primary "$output"
                fi
                if [[ $LLM_WTYPE == true ]]
                then
                    wtype "$output"
                fi
            else
                fyi "LLM output" "$output"
            fi
        fi
    done
}

main "$@"
